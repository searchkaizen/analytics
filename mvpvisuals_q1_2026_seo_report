<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MVP Visuals — SEO Director's Brief, Q1 2026</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Barlow:wght@300;400;500;600&family=Barlow+Condensed:wght@500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
:root {
  --cream: #f5f1ea;
  --white: #ffffff;
  --navy: #0c1928;
  --navy-mid: #1e3048;
  --navy-light: #2e4a6a;
  --ink: #1a2a3a;
  --muted: #5a6878;
  --faint: #9aacba;
  --rule: #ddd8cf;
  --amber: #b87520;
  --amber-bg: #fdf4e7;
  --amber-border: #f0d49a;
  --teal: #0a7060;
  --teal-bg: #eaf4f1;
  --teal-border: #8ec9bf;
  --red: #a82b1e;
  --red-bg: #fdf0ee;
  --red-border: #f0b8b2;
  --blue: #1a4a8a;
  --blue-bg: #eef3fb;
  --font-display: 'Cormorant Garamond', Georgia, serif;
  --font-body: 'Barlow', system-ui, sans-serif;
  --font-condensed: 'Barlow Condensed', sans-serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--cream);
  color: var(--ink);
  font-family: var(--font-body);
  font-size: 14px;
  line-height: 1.65;
  display: flex;
}

/* === NAV === */
nav {
  position: fixed;
  top: 0; left: 0;
  width: 200px;
  height: 100vh;
  background: var(--navy);
  padding: 36px 0 24px;
  display: flex;
  flex-direction: column;
  z-index: 100;
  overflow-y: auto;
}
.nav-mark {
  padding: 0 24px 28px;
  border-bottom: 1px solid rgba(255,255,255,0.08);
  margin-bottom: 24px;
}
.nav-mark .co { font-family: var(--font-condensed); font-size: 13px; font-weight: 600; color: #fff; letter-spacing: 0.05em; text-transform: uppercase; }
.nav-mark .doc { font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 4px; font-family: var(--font-body); font-weight: 300; }
nav a {
  display: block;
  padding: 7px 24px;
  font-size: 11px;
  font-weight: 500;
  color: rgba(255,255,255,0.38);
  text-decoration: none;
  letter-spacing: 0.04em;
  border-left: 2px solid transparent;
  transition: all 0.15s;
  font-family: var(--font-condensed);
  text-transform: uppercase;
}
nav a:hover { color: rgba(255,255,255,0.75); }
nav a.active { color: #fff; border-left-color: var(--amber); background: rgba(255,255,255,0.04); }
.nav-group {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.2);
  padding: 18px 24px 6px;
  font-family: var(--font-condensed);
}
.nav-foot {
  margin-top: auto;
  padding: 20px 24px 0;
  border-top: 1px solid rgba(255,255,255,0.08);
  font-size: 10px;
  color: rgba(255,255,255,0.22);
  line-height: 1.6;
  font-family: var(--font-body);
}

/* === MAIN === */
main { margin-left: 200px; flex: 1; min-height: 100vh; }

/* === COVER === */
.cover {
  background: var(--navy);
  padding: 80px 72px 64px;
  position: relative;
  overflow: hidden;
  min-height: 460px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}
.cover::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 600px 400px at 80% 30%, rgba(184,117,32,0.12) 0%, transparent 70%),
    radial-gradient(ellipse 400px 600px at 10% 80%, rgba(10,112,96,0.08) 0%, transparent 60%);
  pointer-events: none;
}
.cover-meta {
  font-family: var(--font-condensed);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--amber);
  margin-bottom: 20px;
}
.cover h1 {
  font-family: var(--font-display);
  font-size: 54px;
  font-weight: 500;
  line-height: 1.08;
  color: #fff;
  max-width: 700px;
  margin-bottom: 24px;
}
.cover h1 em { font-style: italic; color: rgba(255,255,255,0.65); }
.cover-abstract {
  font-size: 15px;
  font-weight: 300;
  color: rgba(255,255,255,0.65);
  max-width: 620px;
  line-height: 1.75;
  margin-bottom: 52px;
  border-left: 2px solid var(--amber);
  padding-left: 20px;
}
.cover-stats {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 0;
  border-top: 1px solid rgba(255,255,255,0.1);
  padding-top: 32px;
  max-width: 860px;
}
.cstat {
  padding-right: 24px;
  border-right: 1px solid rgba(255,255,255,0.08);
  margin-right: 24px;
}
.cstat:last-child { border-right: none; }
.cstat-label { font-size: 10px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.35); margin-bottom: 6px; font-family: var(--font-condensed); }
.cstat-val { font-family: var(--font-display); font-size: 28px; font-weight: 500; color: #fff; line-height: 1; }
.cstat-delta { font-size: 11px; margin-top: 5px; font-family: var(--font-body); font-weight: 500; }
.d-up { color: #4ecda4; }
.d-down { color: #e0776e; }
.d-flat { color: var(--amber); }
.d-new { color: #9b9ef0; }

/* === SECTIONS === */
section { padding: 72px 72px 0; }
.section-header { margin-bottom: 36px; }
.section-eyebrow {
  font-family: var(--font-condensed);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--amber);
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.section-eyebrow::after { content: ''; flex: 1; height: 1px; background: var(--amber-border); }
.section-header h2 {
  font-family: var(--font-display);
  font-size: 34px;
  font-weight: 500;
  color: var(--navy);
  line-height: 1.2;
}
.section-header h2 em { font-style: italic; color: var(--muted); }
.lead {
  font-size: 15px;
  font-weight: 300;
  color: var(--muted);
  max-width: 780px;
  line-height: 1.8;
  margin-bottom: 40px;
}
.lead strong { font-weight: 600; color: var(--ink); }

/* === LAYOUT === */
.row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px; }
.row3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 24px; margin-bottom: 24px; }
.row-asym { display: grid; grid-template-columns: 1.4fr 1fr; gap: 24px; margin-bottom: 24px; }
.row-asym-r { display: grid; grid-template-columns: 1fr 1.4fr; gap: 24px; margin-bottom: 24px; }

/* === CARDS === */
.card {
  background: var(--white);
  border: 1px solid var(--rule);
  border-radius: 4px;
  padding: 24px 26px;
}
.card-label {
  font-family: var(--font-condensed);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--faint);
  margin-bottom: 16px;
}
.chart-wrap { position: relative; }

/* === STAT TABLE === */
.stat-line {
  display: grid;
  grid-template-columns: 1fr auto auto;
  gap: 12px;
  align-items: baseline;
  padding: 10px 0;
  border-bottom: 1px solid var(--rule);
}
.stat-line:last-child { border-bottom: none; }
.sl-name { font-size: 13px; color: var(--ink); font-weight: 500; }
.sl-name small { display: block; font-size: 11px; color: var(--faint); font-weight: 400; margin-top: 1px; }
.sl-val { font-size: 13px; color: var(--ink); font-family: var(--font-condensed); font-weight: 600; letter-spacing: 0.02em; text-align: right; }
.sl-yoy { font-size: 11px; font-weight: 600; min-width: 52px; text-align: right; font-family: var(--font-condensed); }
.up { color: var(--teal); }
.down { color: var(--red); }
.flat { color: var(--amber); }
.new-tag { color: var(--blue); }

/* === FINDING CARDS === */
.finding {
  background: var(--white);
  border: 1px solid var(--rule);
  border-radius: 4px;
  padding: 22px 24px;
  margin-bottom: 16px;
  position: relative;
  padding-left: 28px;
}
.finding::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 4px;
  border-radius: 4px 0 0 4px;
}
.finding.red::before { background: var(--red); }
.finding.amber::before { background: var(--amber); }
.finding.teal::before { background: var(--teal); }
.finding.blue::before { background: var(--blue); }
.finding-head {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 8px;
}
.f-tag {
  font-family: var(--font-condensed);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 2px 8px;
  border-radius: 3px;
}
.f-tag.red { background: var(--red-bg); color: var(--red); border: 1px solid var(--red-border); }
.f-tag.amber { background: var(--amber-bg); color: var(--amber); border: 1px solid var(--amber-border); }
.f-tag.teal { background: var(--teal-bg); color: var(--teal); border: 1px solid var(--teal-border); }
.f-tag.blue { background: var(--blue-bg); color: var(--blue); border: 1px solid rgba(26,74,138,0.2); }
.finding-title { font-size: 14px; font-weight: 600; color: var(--ink); }
.finding p { font-size: 13px; color: var(--muted); line-height: 1.7; }
.finding p strong { color: var(--ink); font-weight: 600; }

/* === CALLOUT === */
.pullquote {
  border-left: 3px solid var(--navy);
  padding: 20px 24px;
  margin: 32px 0;
  background: var(--white);
  border-radius: 0 4px 4px 0;
}
.pullquote p {
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: 400;
  font-style: italic;
  color: var(--navy);
  line-height: 1.6;
  margin-bottom: 8px;
}
.pullquote cite { font-size: 12px; color: var(--faint); font-style: normal; font-family: var(--font-condensed); letter-spacing: 0.06em; text-transform: uppercase; }

/* === DATA TABLE === */
.tbl-wrap { border: 1px solid var(--rule); border-radius: 4px; overflow: hidden; margin-bottom: 24px; }
table.dt { width: 100%; border-collapse: collapse; font-size: 13px; }
table.dt thead tr { background: var(--navy); }
table.dt th { padding: 10px 14px; text-align: left; font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.5); font-family: var(--font-condensed); }
table.dt th:not(:first-child) { text-align: right; }
table.dt td { padding: 10px 14px; border-bottom: 1px solid var(--rule); color: var(--muted); vertical-align: middle; }
table.dt td:first-child { color: var(--ink); font-weight: 500; }
table.dt td:not(:first-child) { text-align: right; font-family: var(--font-condensed); font-size: 12px; font-weight: 500; }
table.dt tr:hover td { background: var(--cream); }
table.dt tr:last-child td { border-bottom: none; }

/* === METRIC BOX === */
.mbox {
  background: var(--white);
  border: 1px solid var(--rule);
  border-radius: 4px;
  padding: 20px 22px;
}
.mbox-label { font-family: var(--font-condensed); font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--faint); margin-bottom: 8px; }
.mbox-val { font-family: var(--font-display); font-size: 32px; font-weight: 500; color: var(--navy); line-height: 1; }
.mbox-sub { font-size: 12px; color: var(--muted); margin-top: 5px; font-weight: 400; }

/* === FUNNEL STRIP === */
.funnel { display: flex; align-items: stretch; margin-bottom: 16px; }
.fstep { flex: 1; background: var(--white); border: 1px solid var(--rule); padding: 14px 16px; }
.fstep + .fstep { border-left: none; }
.fstep:first-child { border-radius: 4px 0 0 4px; }
.fstep:last-child { border-radius: 0 4px 4px 0; }
.fstep-label { font-size: 10px; font-family: var(--font-condensed); font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--faint); margin-bottom: 4px; }
.fstep-val { font-family: var(--font-display); font-size: 22px; font-weight: 500; color: var(--navy); }
.fstep-rate { font-size: 11px; color: var(--muted); margin-top: 2px; }
.fstep.dim .fstep-val { color: var(--red); }
.farrow { display: flex; align-items: center; padding: 0 8px; color: var(--rule); font-size: 20px; flex-shrink: 0; }

/* === OPPORTUNITY ROW === */
.opp-row {
  display: grid;
  grid-template-columns: 36px 1fr auto;
  gap: 16px;
  align-items: start;
  padding: 20px 0;
  border-bottom: 1px solid var(--rule);
}
.opp-row:last-child { border-bottom: none; }
.opp-num { font-family: var(--font-display); font-size: 28px; font-weight: 400; color: var(--rule); line-height: 1.1; }
.opp-body h4 { font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 4px; }
.opp-body p { font-size: 13px; color: var(--muted); line-height: 1.65; }
.opp-body p strong { color: var(--ink); font-weight: 600; }
.opp-pill {
  font-family: var(--font-condensed);
  font-size: 11px;
  font-weight: 700;
  padding: 5px 12px;
  border-radius: 3px;
  white-space: nowrap;
  margin-top: 4px;
  letter-spacing: 0.04em;
}
.pill-rev { background: var(--teal-bg); color: var(--teal); border: 1px solid var(--teal-border); }
.pill-vis { background: var(--amber-bg); color: var(--amber); border: 1px solid var(--amber-border); }
.pill-struct { background: var(--blue-bg); color: var(--blue); border: 1px solid rgba(26,74,138,0.25); }

/* === DIVIDER === */
hr { border: none; border-top: 1px solid var(--rule); margin: 48px 0; }

/* === STRATEGY MATRIX === */
.matrix { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; margin-bottom: 24px; border: 1px solid var(--rule); border-radius: 4px; overflow: hidden; }
.mquad { background: var(--white); padding: 22px 24px; }
.mquad:nth-child(1) { border-right: 1px solid var(--rule); border-bottom: 1px solid var(--rule); }
.mquad:nth-child(2) { border-bottom: 1px solid var(--rule); }
.mquad:nth-child(3) { border-right: 1px solid var(--rule); }
.mquad h4 { font-size: 12px; font-weight: 700; font-family: var(--font-condensed); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 10px; }
.mquad h4.invest { color: var(--teal); }
.mquad h4.maintain { color: var(--amber); }
.mquad h4.audit { color: var(--red); }
.mquad h4.watch { color: var(--blue); }
.mquad ul { list-style: none; }
.mquad li { font-size: 13px; color: var(--muted); padding: 4px 0; border-bottom: 1px dotted var(--rule); }
.mquad li:last-child { border-bottom: none; }
.mquad li::before { content: '→  '; color: var(--faint); font-weight: 500; }

/* === NOTE === */
.note {
  background: var(--amber-bg);
  border: 1px solid var(--amber-border);
  border-radius: 4px;
  padding: 14px 18px;
  font-size: 13px;
  color: #6b4e00;
  line-height: 1.65;
  margin-bottom: 24px;
}
.note strong { font-weight: 600; color: #4a3600; }

/* === PAGE END === */
.report-end {
  padding: 60px 72px 80px;
  border-top: 1px solid var(--rule);
  margin-top: 64px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
}
</style>
</head>
